{
    "manifest_version": 3,
    "name": "ConvoShield AI",
    "version": "1.0",
    "description": "Scan WhatsApp Web conversations for scams, grooming, and manipulation using NVIDIA AI.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://web.whatsapp.com/*",
        "https://integrate.api.nvidia.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://web.whatsapp.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "ConvoShield AI"
    }
}